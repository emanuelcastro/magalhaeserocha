---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { autores } from '../lib/autores';

const noticias = await getCollection('noticias');
const artigos = await getCollection('artigos');

const conteudo = [
  ...noticias.map((post) => ({ ...post, kind: 'noticia' as const, href: `/noticias/${post.id}/` })),
  ...artigos.map((post) => ({ ...post, kind: 'artigo' as const, href: `/artigos/${post.id}/` })),
]
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

// Coordenadas convertidas de lat/long real para o viewBox do contorno do Brasil
// (base: bbox real ~lat 5.27..-33.75, long -73.99..-34.79 → bbox svg 227.59,520.14..322.47,618.46)
const fortaleza = { nome: 'Fortaleza · CE', x: 313.49, y: 542.75 };
const pinsCobertura = [
  { nome: 'Manaus · AM', x: 261.46, y: 541.23 },
  { nome: 'Belém · PA', x: 289.29, y: 537.07 },
  { nome: 'São Luís · MA', x: 299.45, y: 539.79 },
  { nome: 'Natal · RN', x: 321.45, y: 548.02 },
  { nome: 'Recife · PE', x: 322.2, y: 553.71 },
  { nome: 'Salvador · BA', x: 313.47, y: 566.11 },
  { nome: 'Brasília · DF', x: 290.74, y: 573.23 },
  { nome: 'Goiânia · GO', x: 287.47, y: 575.46 },
  { nome: 'Campo Grande · MS', x: 274.41, y: 584.94 },
  { nome: 'Belo Horizonte · MG', x: 300.33, y: 583.61 },
  { nome: 'São Paulo · SP', x: 293.88, y: 592.64 },
  { nome: 'Rio de Janeiro · RJ', x: 302.19, y: 591.16 },
  { nome: 'Curitiba · PR', x: 287.42, y: 597.5 },
  { nome: 'Porto Alegre · RS', x: 282.75, y: 609.04 },
  { nome: 'Boa Vista · RR', x: 259.83, y: 526.32 },
].map((p, i) => ({ ...p, delay: `${((i * 0.35) % 2.6).toFixed(2)}s` }));
---
<Base title="Magalhães e Rocha Advogados — Fortaleza/CE">
  <section class="hero" style="padding:0;">
    <div class="wrap">
      <div class="hero-copy">
        <span class="eyebrow">Magalhães e Rocha Advogados &mdash; Fortaleza/CE</span>
        <h1>Quem protege o trabalhador. Quem protege o negócio <em>na era dos dados</em>.</h1>
        <p class="lede">Duas sócias-fundadoras, duas frentes de atuação sob o mesmo compromisso técnico: uma defende quem trabalha, a outra defende quem lidera empresas diante da LGPD e do direito digital.</p>
        <div class="hero-actions">
          <a class="btn btn-coral" href="https://wa.me/5585999371776" target="_blank" rel="noopener">Falar no WhatsApp</a>
          <a class="btn btn-outline-light" href="#socias">Conhecer as sócias</a>
        </div>
        <div class="hero-oab">
          <div><span class="n">OAB/CE 22.838</span><span class="l">Rosinê Magalhães</span></div>
          <div><span class="n">OAB/CE 39.149</span><span class="l">Larissa Rocha</span></div>
        </div>
      </div>
      <div class="hero-figure">
        <img src="/images/socias/socias-dupla.jpg" alt="Dra. Rosinê Magalhães e Dra. Larissa Rocha, sócias-fundadoras do escritório" />
      </div>
    </div>
  </section>

  <section id="areas">
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow">Áreas de Atuação</span>
        <h2>Sete frentes, um mesmo rigor técnico</h2>
        <p>Da defesa do trabalhador à conformidade com a LGPD &mdash; organizadas nas três frentes que sustentam o escritório: trabalhista, empresarial &amp; digital, e a base cível comum às duas sócias.</p>
      </div>

      <div class="area-cluster reveal">
        <h3 class="cluster-title">Frente Trabalhista <span>&mdash; Dra. Rosinê Magalhães</span></h3>
        <div class="areas-grid areas-grid-2">
          <article class="area-card">
            <h4>Direito do Trabalho</h4>
            <p>Rescisão e verbas rescisórias, horas extras, assédio moral e sexual, reconhecimento de vínculo e estabilidade de gestantes &mdash; para empregados; defesa em reclamações trabalhistas e compliance trabalhista &mdash; para empresas.</p>
          </article>
          <article class="area-card">
            <h4>Acidente de Trabalho e Doenças Ocupacionais</h4>
            <p>Reconhecimento de acidentes e doenças como LER/DORT, emissão de CAT, estabilidade provisória de 12 meses e indenizações por danos morais, materiais e estéticos &mdash; com histórico de negociações acima de R$ 1,3 milhão.</p>
          </article>
        </div>
      </div>

      <div class="area-cluster reveal">
        <h3 class="cluster-title">Empresarial &amp; Digital <span>&mdash; Dra. Larissa Rocha</span></h3>
        <div class="areas-grid areas-grid-3">
          <article class="area-card">
            <h4>Direito Empresarial</h4>
            <p>Constituição de empresas, contratos empresariais, governança corporativa, fusões e aquisições, recuperação judicial e extrajudicial e propriedade intelectual &mdash; para sociedades de todos os portes e startups.</p>
          </article>
          <article class="area-card">
            <h4>Proteção de Dados &amp; LGPD</h4>
            <p>Mapeamento de dados, políticas de privacidade, nomeação de DPO, gestão de incidentes e Relatório de Impacto &mdash; conduzidos por advogada referenciada pelo STJ em bibliografia sobre o tema.</p>
          </article>
          <article class="area-card">
            <h4>Direito Digital</h4>
            <p>Golpes e fraudes digitais, recuperação de contas, reputação online, contratos eletrônicos, herança digital e regulação de IA, blockchain e criptoativos.</p>
          </article>
        </div>
      </div>

      <div class="area-cluster reveal">
        <h3 class="cluster-title">Civil &amp; Consumidor <span>&mdash; base comum do escritório</span></h3>
        <div class="areas-grid areas-grid-2">
          <article class="area-card">
            <h4>Direito Civil</h4>
            <p>Contratos, direito de família e sucessões, responsabilidade civil, questões imobiliárias e patrimoniais, e litígios contratuais.</p>
          </article>
          <article class="area-card">
            <h4>Direito do Consumidor</h4>
            <p>Cobranças indevidas, produtos defeituosos, publicidade enganosa, negativação indevida em SPC/Serasa e problemas com passagens aéreas e planos de saúde.</p>
          </article>
        </div>
      </div>
    </div>
  </section>

  <section id="socias" style="background:#fff;">
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow">Sócias-fundadoras</span>
        <h2>Quem assina cada caso</h2>
        <p>Duas advogadas, duas especializações complementares &mdash; a experiência consolidada do contencioso trabalhista e a vanguarda da proteção de dados.</p>
      </div>

      <article class="socia reveal">
        <div class="socia-figure">
          <img src="/images/socias/rosine-magalhaes.jpg" alt="Retrato da Dra. Rosinê Magalhães" />
          <span class="socia-tag">OAB/CE 22.838</span>
        </div>
        <div class="socia-copy">
          <h3>Dra. Rosinê Magalhães</h3>
          <span class="cargo">Direito do Trabalho &middot; Acidentes e Doenças Ocupacionais</span>
          <p class="bio">Sócia-fundadora do escritório, defende trabalhadores em casos de acidente de trabalho e doença ocupacional, com histórico de negociações acima de R$ 1,3 milhão. Atua também na prevenção e mitigação de riscos trabalhistas junto a empresas.</p>
          <ul class="credenciais">
            <li>Especialista em Processo do Trabalho e Processo Civil &mdash; UNIFOR</li>
            <li>Ex-mediadora do Tribunal de Justiça do Ceará</li>
            <li>Membro da Comissão de Direito do Trabalho da OAB/CE</li>
            <li>Membro da Comissão de Direito Previdenciário da OAB/CE</li>
          </ul>
        </div>
      </article>

      <article class="socia reveal">
        <div class="socia-figure">
          <img src="/images/socias/larissa-rocha.jpg" alt="Retrato da Dra. Larissa Rocha" />
          <span class="socia-tag">OAB/CE 39.149</span>
        </div>
        <div class="socia-copy">
          <h3>Dra. Larissa Rocha</h3>
          <span class="cargo">Proteção de Dados &middot; Direito Digital &middot; Empresarial</span>
          <p class="bio">Sócia-fundadora do escritório, lidera a atuação em Proteção de Dados, Direito Digital e Empresarial. Mestre em Direito pela UFC e doutoranda em Direito Empresarial pela UERJ, foi referenciada nas bibliografias selecionadas sobre LGPD do Superior Tribunal de Justiça em 2024.</p>
          <ul class="credenciais">
            <li>Certificações internacionais em LGPD, GDPR, ISO 27001, ISO 27005 e DPO &mdash; ITCERTS</li>
            <li>Extensão em Direito Digital e Proteção de Dados &mdash; PUC/SP</li>
            <li>Membro da Comissão de LGPD da OAB/CE</li>
            <li>Membro da Comissão de Startups e Direito Digital da OAB/CE</li>
          </ul>
        </div>
      </article>
    </div>
  </section>

  <section class="proof">
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow">Credenciais</span>
        <h2>Rigor técnico, dos dois lados da mesa</h2>
      </div>
      <div class="proof-grid reveal">
        <div class="proof-item">
          <div class="stat">R$ 1,3 M+</div>
          <div class="label">em negociações trabalhistas já conduzidas pelo escritório</div>
        </div>
        <div class="proof-item">
          <div class="stat">STJ &middot; 2024</div>
          <div class="label">Dra. Larissa Rocha referenciada em bibliografia oficial sobre LGPD</div>
        </div>
        <div class="proof-item">
          <div class="stat">4 comissões</div>
          <div class="label">as sócias somam quatro assentos em comissões da OAB/CE</div>
        </div>
      </div>
    </div>
  </section>

  <section id="noticias">
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow">Notícias &amp; Artigos</span>
        <h2>Conteúdo direto do escritório</h2>
        <p>Esta área é alimentada pelas próprias sócias, sem depender de programação &mdash; atualizações rápidas em <a href="/noticias/">Notícias</a> e análises mais aprofundadas em <a href="/artigos/">Artigos</a>.</p>
      </div>

      {conteudo.length === 0 ? (
        <div class="news-shell reveal">
          <span class="mark">Em preparação</span>
          <h3>Os primeiros textos estão sendo escritos</h3>
          <p>Quando publicados, aparecerão aqui como matérias completas, com data, tema e leitura estimada &mdash; iguais em prioridade ao restante do site.</p>
          <div class="news-topics">
            <span>Direito do Trabalho</span>
            <span>LGPD &amp; Proteção de Dados</span>
            <span>Direito Civil</span>
          </div>
        </div>
      ) : (
        <div class="news-grid reveal">
          {conteudo.map((post) => (
            <a class="news-card" href={post.href}>
              <div class="autor">
                <img class="autor-avatar" src={autores[post.data.autor].foto} alt="" />
                <span class="autor-nome">{autores[post.data.autor].nome}</span>
              </div>
              <span class="news-date">
                <span class="news-kind">{post.kind === 'noticia' ? 'Notícia' : 'Artigo'}</span>
                {post.data.date.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}
              </span>
              <h3>{post.data.title}</h3>
              <p>{post.data.excerpt}</p>
              <span class="news-link">Ler mais &rarr;</span>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <section class="cobertura">
    <div class="wrap cobertura-grid">
      <div class="cobertura-copy reveal">
        <span class="eyebrow">Cobertura Nacional</span>
        <h2>Do Ceará para o Brasil inteiro</h2>
        <p>A sede é em Fortaleza, mas o atendimento não tem fronteira &mdash; consultas e acompanhamento processual acontecem online, para clientes em qualquer estado do país.</p>
        <a class="btn btn-coral" href="https://wa.me/5585999371776" target="_blank" rel="noopener">Agendar atendimento</a>
      </div>
      <div class="cobertura-map reveal">
        <svg viewBox="223.59 516.14 102.88 106.32" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Mapa do Brasil com pontos de atendimento em todas as regiões, com destaque para a sede em Fortaleza, Ceará">
          <defs>
            <radialGradient id="mapaGlow" cx="50%" cy="45%" r="65%">
              <stop offset="0%" stop-color="var(--marinho-mid)" stop-opacity="0.9" />
              <stop offset="100%" stop-color="var(--marinho-mid)" stop-opacity="0" />
            </radialGradient>
          </defs>
          <circle class="mapa-glow" cx="275" cy="565" r="52" fill="url(#mapaGlow)" />
          <path class="brasil-silhueta" d="M286.631,618.464l5.402-10.391l0.198-8.73l10.079-6.501h5.645l4.435-7.512l0.804-14.418l-1.815-3.855l10.684-9.751l0.406-10.761l-14.514-7.105l-17.53-5.48l-8.264-0.812l2.221-4.669l-0.604-7.104l-1.808-0.596l-2.671,5.308l-1.4,1.754l-3.595-1.59l-12.093,4.261l-4.028-5.073l0.648-5.299l-3.804,3.872l-4.201-2.265l-0.424,0.597l0.009,1.841l3.622,1.945l-5.437,5.73l-3.432-0.034l-3.475-3.535l-3.933,0.121l-0.484,4.2l2.256,2.739l-2.663,8.532l-3.112,0.241l-4.953,3.13l-1.21,6.146l4.296,4.599l0.787-0.89l3.017-0.812l2.576,4.34l7.374-3.164l2.861,0.165l1.971,6.976l10.52,3.337l1.815,5.564l4.478,0.537l2.135,5.314l-1.443,4.729l1.884,2.474l-0.276,3.683l5.048-0.477l4.625,5.844l-0.363,4.105l2.74,2.316l-6.57,9.95L286.631,618.464L286.631,618.464z"/>

          <g class="pin-lines">
            {pinsCobertura.map((p) => (
              <line x1={fortaleza.x} y1={fortaleza.y} x2={p.x} y2={p.y} />
            ))}
          </g>

          {pinsCobertura.map((p) => (
            <g class="pin" style={`--delay:${p.delay}`} transform={`translate(${p.x},${p.y})`}>
              <circle class="pin-ping" r="1.8" />
              <circle class="pin-dot" r="0.85" />
            </g>
          ))}

          <g class="pin pin-home" style="--delay:0s" transform={`translate(${fortaleza.x},${fortaleza.y})`}>
            <circle class="pin-ping" r="2.6" />
            <circle class="pin-dot" r="1.6" />
          </g>
          <text class="mapa-rotulo" x={fortaleza.x} y="533.5" text-anchor="middle">{fortaleza.nome}</text>
        </svg>
      </div>
    </div>
  </section>

  <section class="contato" id="contato">
    <div class="wrap">
      <div class="contato-grid">
        <div class="contato-copy reveal">
          <span class="eyebrow" style="color:var(--coral);">Contato</span>
          <h2>Fale direto com o escritório</h2>
          <p>Atendimento inicial por WhatsApp &mdash; conte brevemente o seu caso e uma das sócias responde pessoalmente.</p>
          <div class="contato-actions">
            <a class="btn btn-coral" href="https://wa.me/5585999371776" target="_blank" rel="noopener">(85) 99937-1776 &middot; WhatsApp</a>
          </div>
        </div>
        <div class="contato-card reveal">
          <span class="eyebrow">Escritório</span>
          <div class="contato-line"><span class="k">Telefone</span><span class="v">(85) 99937-1776</span></div>
          <div class="contato-line"><span class="k">Base</span><span class="v">Fortaleza &middot; CE</span></div>
          <div class="contato-line"><span class="k">OAB/CE</span><span class="v">22.838 &middot; 39.149</span></div>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ---------- hero ---------- */
  .hero{
    background:linear-gradient(160deg, var(--marinho) 0%, var(--marinho-deep) 100%);
    color:#fff;position:relative;overflow:hidden;
  }
  .hero .wrap{
    display:grid;grid-template-columns:1.05fr 0.85fr;gap:0;align-items:stretch;
    min-height:640px;
  }
  .hero-copy{padding:88px 56px 64px 0;display:flex;flex-direction:column;justify-content:center;gap:26px;position:relative;z-index:2;}
  .hero-copy .eyebrow{color:var(--latao);}
  .hero-copy h1{font-size:clamp(34px,4.6vw,54px);line-height:1.08;color:#fff;font-weight:600;}
  .hero-copy h1 em{font-style:italic;font-weight:500;color:#f3d9c4;}
  .hero-copy .lede{font-size:18px;color:rgba(255,255,255,0.82);max-width:46ch;line-height:1.6;}
  .hero-actions{display:flex;gap:14px;flex-wrap:wrap;margin-top:6px;}
  .hero-oab{display:flex;gap:28px;margin-top:18px;padding-top:22px;border-top:1px solid rgba(255,255,255,0.18);}
  .hero-oab div{display:flex;flex-direction:column;gap:3px;}
  .hero-oab .n{font-family:var(--serif);font-size:15px;color:#fff;font-weight:600;}
  .hero-oab .l{font-size:11.5px;letter-spacing:.08em;text-transform:uppercase;color:rgba(255,255,255,0.6);}

  .hero-figure{position:relative;}
  .hero-figure img{
    position:absolute;bottom:0;right:-8%;height:104%;width:auto;max-width:none;
    object-fit:cover;
  }
  @media (max-width:860px){
    .hero .wrap{grid-template-columns:1fr;min-height:0;}
    .hero-copy{padding:52px 0 32px;}
    .hero-figure{height:420px;order:-1;}
    .hero-figure img{position:static;height:100%;width:100%;object-fit:cover;object-position:top center;}
  }

  /* ---------- areas ---------- */
  .area-cluster + .area-cluster{margin-top:48px;}
  .cluster-title{
    display:flex;align-items:baseline;gap:10px;flex-wrap:wrap;
    font-family:var(--sans);font-size:13px;font-weight:800;letter-spacing:.08em;text-transform:uppercase;
    color:var(--marinho);margin:0 0 22px;padding-bottom:14px;border-bottom:1px solid var(--linha);
  }
  .cluster-title span{font-weight:600;text-transform:none;letter-spacing:0;color:var(--grafite-soft);font-size:13.5px;font-family:var(--serif);font-style:italic;}
  .areas-grid{display:grid;gap:24px;}
  .areas-grid-2{grid-template-columns:1fr 1fr;}
  .areas-grid-3{grid-template-columns:repeat(3,1fr);}
  @media (max-width:780px){.areas-grid-2, .areas-grid-3{grid-template-columns:1fr;}}
  .area-card{
    background:#fff;border:1px solid var(--linha);padding:30px 28px;
    display:flex;flex-direction:column;gap:12px;position:relative;
  }
  .area-card::before{content:"";position:absolute;top:-1px;left:28px;width:32px;height:3px;background:var(--latao);}
  .area-card h4{font-family:var(--serif);font-weight:600;font-size:19px;color:var(--marinho);padding-top:8px;margin:0;}
  .area-card p{color:var(--grafite-soft);font-size:14.5px;line-height:1.6;margin:0;}

  /* ---------- socias ---------- */
  .socia{
    display:grid;grid-template-columns:340px 1fr;gap:60px;align-items:start;
    padding-block:56px;
  }
  .socia + .socia{border-top:1px solid var(--linha);}
  .socia:nth-of-type(2){grid-template-columns:1fr 340px;}
  .socia:nth-of-type(2) .socia-figure{order:2;}
  .socia:nth-of-type(2) .socia-copy{order:1;}
  @media (max-width:820px){
    .socia, .socia:nth-of-type(2){grid-template-columns:1fr;gap:28px;}
    .socia:nth-of-type(2) .socia-figure, .socia:nth-of-type(2) .socia-copy{order:initial;}
  }
  .socia-figure img{width:100%;aspect-ratio:4/5;object-fit:cover;object-position:top center;}
  .socia-tag{display:inline-block;margin-top:14px;font-family:var(--sans);font-weight:700;font-size:11.5px;letter-spacing:.1em;color:var(--marinho);text-transform:uppercase;}
  .socia-copy h3{font-size:30px;color:var(--marinho);}
  .socia-copy .cargo{font-family:var(--serif);font-style:italic;font-size:16px;color:var(--coral);margin-top:6px;display:block;}
  .socia-copy .bio{margin-top:20px;font-size:16px;color:var(--grafite);max-width:64ch;line-height:1.65;}
  .credenciais{list-style:none;margin:24px 0 0;padding:0;display:flex;flex-direction:column;gap:9px;}
  .credenciais li{
    font-size:14px;color:var(--grafite-soft);padding-left:18px;position:relative;
  }
  .credenciais li::before{
    content:"";position:absolute;left:0;top:9px;width:7px;height:1px;background:var(--latao);
  }

  /* ---------- proof band ---------- */
  .proof{background:var(--marinho);color:#fff;}
  .proof .section-head h2{color:#fff;}
  .proof .section-head p{color:rgba(255,255,255,0.72);}
  .proof .section-head .eyebrow{color:var(--latao);}
  .proof-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(255,255,255,0.15);border:1px solid rgba(255,255,255,0.15);}
  @media (max-width:780px){.proof-grid{grid-template-columns:1fr;}}
  .proof-item{background:var(--marinho-deep);padding:38px 34px;}
  .proof-item .stat{font-family:var(--serif);font-size:38px;font-weight:600;font-variant-numeric:tabular-nums;color:#fff;}
  .proof-item .label{margin-top:10px;font-size:14.5px;color:rgba(255,255,255,0.75);line-height:1.5;}

  /* ---------- news (empty state) ---------- */
  .news-shell{
    border:1px dashed var(--linha);
    padding:64px 48px;text-align:center;
    display:flex;flex-direction:column;align-items:center;gap:16px;
    background:#fff;
  }
  .news-shell .mark{font-family:var(--serif);font-style:italic;font-size:22px;color:var(--latao);}
  .news-shell h3{font-size:24px;color:var(--marinho);max-width:32ch;}
