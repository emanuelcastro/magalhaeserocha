<footer>
  <div class="wrap">
    <div class="footer-top">
      <div class="footer-brand">
        <img src="/images/logo/icone-app-navy.jpg" alt="Emblema Magalhães e Rocha Advogados" width="36" height="36" />
        <span>Magalhães e Rocha Advogados</span>
      </div>
      <div class="footer-oab">
        <span>OAB/CE 22.838 &mdash; Rosinê Magalhães</span>
        <span>OAB/CE 39.149 &mdash; Larissa Rocha</span>
      </div>
      <!-- TODO: trocar "#" pelos links reais assim que fornecidos -->
      <div class="footer-social">
        <a href="#" aria-label="Instagram" class="footer-social-link">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8">
            <rect x="3" y="3" width="18" height="18" rx="5"/>
            <circle cx="12" cy="12" r="4.2"/>
            <circle cx="17.2" cy="6.8" r="1.1" fill="currentColor" stroke="none"/>
          </svg>
        </a>
        <a href="#" aria-label="Facebook" class="footer-social-link">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8">
            <rect x="3" y="3" width="18" height="18" rx="5"/>
            <path d="M13.5 21v-7h2.2l.3-2.6h-2.5V9.7c0-.75.2-1.26 1.28-1.26h1.37V5.1C15.86 5.03 15.03 5 14.06 5c-2.1 0-3.56 1.28-3.56 3.63v2.02H8.3v2.6h2.2v6.75"/>
          </svg>
        </a>
        <a href="#" aria-label="LinkedIn" class="footer-social-link">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8">
            <rect x="3" y="3" width="18" height="18" rx="5"/>
            <circle cx="7.5" cy="8" r="1.1" fill="currentColor" stroke="none"/>
            <path d="M7.5 11v6M11 17v-3.5c0-1.8 1.2-2.7 2.4-2.7 1.3 0 2.1.9 2.1 2.8V17" stroke-linecap="round"/>
          </svg>
        </a>
      </div>
    </div>
    <div class="footer-bottom">
      <span>&copy; {new Date().getFullYear()} Magalhães e Rocha Advogados. Todos os direitos reservados.</span>
      <span>Site em atualização contínua</span>
    </div>
  </div>
</footer>
